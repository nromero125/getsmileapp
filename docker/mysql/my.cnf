[mysqld]
# Charset
character-set-server = utf8mb4
collation-server     = utf8mb4_unicode_ci

# Performance (ajustar según RAM disponible)
innodb_buffer_pool_size    = 512M   # ~10% de la RAM total del VPS
innodb_log_file_size       = 128M
innodb_flush_log_at_trx_commit = 2   # mejor rendimiento, mínimo riesgo de pérdida
innodb_flush_method        = O_DIRECT
max_connections            = 150
query_cache_type           = 0       # desactivado en MySQL 8

# Logs (desactivar en producción si no los necesitas)
slow_query_log  = 1
slow_query_log_file = /var/lib/mysql/slow.log
long_query_time = 2

[client]
default-character-set = utf8mb4
